// LeetCode #91 Decode Ways — correctness suite.
//
// One `test "..." { ... }` block per reference case. The block-form
// surface (design.md § Testing) replaces the historical
// `report + python-diff` correctness loop with inline expected values:
// each case names the input + expected count in its title and asserts
// the same number in the body, so a failing test surfaces both the
// input and the expected/actual pair in the JSONL `test_fail` event
// without consulting a peer Python file.
//
// The Python mirror (`../decode_ways.py`) stays as a peer reference
// implementation for reading-by-example and as a paper-trail of the
// recurrence; it is no longer the diff target for correctness.

// ── LeetCode reference cases ────────────────────────────────────

test "12 → 2 (AB | L)" {
    assert_eq(decode_ways("12"), 2);
}

test "226 → 3 (BBF | BZ | VF)" {
    assert_eq(decode_ways("226"), 3);
}

test "leading zero is invalid" {
    assert_eq(decode_ways("06"), 0);
}

// ── Mid-stream zero behaviour ───────────────────────────────────

test "10 → 1 (J — trailing 0 attaches to leading 1)" {
    assert_eq(decode_ways("10"), 1);
}

test "100 → 0 (00 and bare 0 both invalid)" {
    assert_eq(decode_ways("100"), 0);
}

test "101 → 1 (JA — mid-stream 0 does not poison the rest)" {
    assert_eq(decode_ways("101"), 1);
}

test "110 → 1 (KJ — only path through the trailing 0)" {
    assert_eq(decode_ways("110"), 1);
}

test "301 → 0 (30 out of range, 0 invalid alone)" {
    assert_eq(decode_ways("301"), 0);
}

test "230 → 0 (30 out of range, alternate split has bare 0)" {
    assert_eq(decode_ways("230"), 0);
}

test "27 → 1 (BG — 27 exceeds two-digit limit)" {
    assert_eq(decode_ways("27"), 1);
}

// ── Empty and single-digit ──────────────────────────────────────

test "empty input → 0" {
    assert_eq(decode_ways(""), 0);
}

test "single 0 → 0" {
    assert_eq(decode_ways("0"), 0);
}

test "single 1 → 1 (A)" {
    assert_eq(decode_ways("1"), 1);
}

test "single 9 → 1 (I)" {
    assert_eq(decode_ways("9"), 1);
}

// ── All-ones: Fibonacci sequence ────────────────────────────────
//
// Every adjacent pair is a valid two-digit key, so dp[n] = F(n+1).

test "11 → 2 (F(3))" {
    assert_eq(decode_ways("11"), 2);
}

test "111 → 3 (F(4))" {
    assert_eq(decode_ways("111"), 3);
}

test "1111 → 5 (F(5))" {
    assert_eq(decode_ways("1111"), 5);
}

test "11111 → 8 (F(6))" {
    assert_eq(decode_ways("11111"), 8);
}

test "111111 → 13 (F(7))" {
    assert_eq(decode_ways("111111"), 13);
}

// ── Long mixed cases ────────────────────────────────────────────

test "123123 → 9 (mixed splits diverge from Fibonacci)" {
    assert_eq(decode_ways("123123"), 9);
}

test "1234567 → 3 (only first two pairs are two-digit valid)" {
    assert_eq(decode_ways("1234567"), 3);
}

test "2611055971756562 → 4 (long mixed, mid-stream 0 at position 5)" {
    assert_eq(decode_ways("2611055971756562"), 4);
}
