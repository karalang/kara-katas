// Benchmark workload — Restore IP Addresses (LeetCode #93).
// The kata's engine is the segment enumeration + validation (which cut points give four
// valid 0..255 segments). Building the address strings would make this an allocation
// bench, so instead the bench FOLDS the segment values of every valid quadruple through
// a rolling polynomial hash — no strings. To keep each call doing different work (so
// nothing hoists), the digits are computed inline from the iteration index
// (`digit(pos) = (pos*7 + iter) % 10`, no array), and the three-dot triple loop with the
// leading-zero / <=255 validity test runs over them. CRUCIALLY the input length varies
// per iteration (`n = 4 + iter%9`, i.e. 4..12 — the real range for a restorable string),
// so no engine can statically unroll/vectorize a fixed 12-element enumeration and erase
// the checked scalar work (that degenerate fixed-shape version distorted the bench — see
// CLAUDE.md "vectorizable loop" pitfall). K=6,500,000 iterations. See ../README.md.

fn digit(pos: i64, iter: i64) -> i64 {
    (pos * 7i64 + iter) % 10i64
}

// Segment value if the [start, start+len) window is a valid IP segment, else -1.
fn seg_val(start: i64, len: i64, iter: i64) -> i64 {
    if len < 1i64 or len > 3i64 {
        return -1i64;
    }
    if len > 1i64 and digit(start, iter) == 0i64 {
        return -1i64;                          // leading zero
    }
    let mut v = 0i64;
    let mut i = 0i64;
    while i < len {
        v = v * 10i64 + digit(start + i, iter);
        i = i + 1i64;
    }
    if v > 255i64 {
        return -1i64;
    }
    v
}

fn restore_fold(n: i64, iter: i64, seed: i64) -> i64 {
    let mut acc = seed;
    let mut a = 1i64;
    while a <= 3i64 and a < n {
        let v0 = seg_val(0i64, a, iter);
        if v0 >= 0i64 {
            let mut b = a + 1i64;
            while b <= a + 3i64 and b < n {
                let v1 = seg_val(a, b - a, iter);
                if v1 >= 0i64 {
                    let mut c = b + 1i64;
                    while c <= b + 3i64 and c < n {
                        let v2 = seg_val(b, c - b, iter);
                        let v3 = seg_val(c, n - c, iter);
                        if v2 >= 0i64 and v3 >= 0i64 {
                            acc = (acc * 131i64 + v0 * 1000000i64 + v1 * 10000i64
                                + v2 * 100i64 + v3 + 1i64) % 1000000007i64;
                        }
                        c = c + 1i64;
                    }
                }
                b = b + 1i64;
            }
        }
        a = a + 1i64;
    }
    acc
}

fn main() {
    let total = 6500000i64;
    let modulus = 1000000007i64;

    let mut sum = 0i64;
    let mut iter = 0i64;
    while iter < total {
        let n = 4i64 + (iter % 9i64);          // 4..12 — data-dependent length
        sum = (sum * 131i64 + restore_fold(n, iter, iter)) % modulus;
        iter = iter + 1i64;
    }
    println(f"{sum}");
}
