// LeetCode #393: UTF-8 Validation — one-pass scan over a byte buffer,
// classifying each leading byte by its high bits and verifying the right
// number of `10xxxxxx` continuation bytes follow. O(n) time, O(1) extra.
//
// A UTF-8 character is 1–4 bytes, discriminated entirely by the leading
// byte's high bits:
//
//   0xxxxxxx                                              → 1 byte  (ASCII)
//   110xxxxx 10xxxxxx                                     → 2 bytes
//   1110xxxx 10xxxxxx 10xxxxxx                            → 3 bytes
//   11110xxx 10xxxxxx 10xxxxxx 10xxxxxx                   → 4 bytes
//
// Anything else as a leading byte (a bare `10xxxxxx` continuation, or
// `11111xxx`) is invalid; and each declared character must have exactly
// its continuation bytes present and well-formed, or the buffer is
// truncated / corrupt.
//
// This is a deliberately byte-level kata — it dogfoods the `u8` surface
// end to end: hex `u8` literals, bitwise `&` masking, `Vec[u8]` building
// and indexing, and `for b in s.bytes()` (the byte iterator). The
// `s.bytes()` path doubles as a property check: every well-formed Kāra
// `String` is valid UTF-8 by construction, so feeding `s.bytes()` through
// the validator must always return `true` — a cross-check that the
// validator and the runtime's UTF-8 invariant agree.

// Number of bytes the character starting with leading byte `b` occupies,
// or 0 if `b` is not a valid UTF-8 leading byte. The masks isolate the
// high bits: `b & 0x80 == 0` is `0xxxxxxx`; `b & 0xE0 == 0xC0` is
// `110xxxxx`; and so on up to `11110xxx`.
fn lead_len(b: u8) -> i64 {
    if b & 0x80u8 == 0x00u8 {
        1i64
    } else if b & 0xE0u8 == 0xC0u8 {
        2i64
    } else if b & 0xF0u8 == 0xE0u8 {
        3i64
    } else if b & 0xF8u8 == 0xF0u8 {
        4i64
    } else {
        0i64
    }
}

// A continuation byte is `10xxxxxx`.
fn is_continuation(b: u8) -> bool {
    b & 0xC0u8 == 0x80u8
}

fn validate_utf8(data: ref Vec[u8]) -> bool {
    let n = data.len();
    let mut i = 0i64;
    while i < n {
        let need = lead_len(data[i]);
        if need == 0i64 {
            // Not a valid leading byte (bare continuation or 0b11111xxx).
            return false;
        }
        if i + need > n {
            // The character's continuation bytes run past the buffer end.
            return false;
        }
        // Verify the `need - 1` following bytes are all continuations.
        let mut k = 1i64;
        while k < need {
            if not is_continuation(data[i + k]) {
                return false;
            }
            k = k + 1i64;
        }
        i = i + need;
    }
    true
}

// Validate a slice of bytes and print the verdict. The `Slice[u8]` is
// copied into a `Vec[u8]` (iterating the slice) so `validate_utf8` works
// against the indexable buffer. Call sites slice a named array local —
// `let a = [...]; validate_lit("...", a[0..n])` — because codegen
// range-slicing requires a named source variable.
fn validate_lit(name: ref String, lit: Slice[u8]) {
    let mut v: Vec[u8] = Vec.new();
    for b in lit {
        v.push(b);
    }
    println(f"{name} -> {validate_utf8(v)}");
}

// Property check: a real UTF-8 `String`'s bytes must always validate.
// Drives `for b in s.bytes()` to materialise the byte buffer.
fn report_str(s: ref String) {
    let mut v: Vec[u8] = Vec.new();
    for b in s.bytes() {
        v.push(b);
    }
    println(f"bytes(\"{s}\") -> {validate_utf8(v)}");
}

fn main() {
    // LeetCode's two canonical examples.
    let c0 = [197u8, 130u8, 1u8];
    validate_lit("[197,130,1]", c0[0..3]); // true  (2-byte char + ASCII)
    let c1 = [235u8, 140u8, 4u8];
    validate_lit("[235,140,4]", c1[0..3]); // false (3-byte lead, 3rd byte not a continuation)

    // Single-byte / ASCII.
    let c2 = [0u8];
    validate_lit("empty", c2[0..0]); // true  (nothing to validate)
    let c3 = [65u8];
    validate_lit("[65]", c3[0..1]); // true  ('A')

    // Well-formed multi-byte characters.
    let c4 = [0xC5u8, 0x82u8];
    validate_lit("[0xC5,0x82]", c4[0..2]); // true  (ł, 2 bytes)
    let c5 = [0xEBu8, 0x8Cu8, 0x95u8];
    validate_lit("[0xEB,0x8C,0x95]", c5[0..3]); // true (3 bytes)
    let c6 = [0xF0u8, 0x9Fu8, 0x98u8, 0x81u8];
    validate_lit("[0xF0,0x9F,0x98,0x81]", c6[0..4]); // true (😁, 4 bytes)

    // Malformed inputs.
    let c7 = [0x80u8];
    validate_lit("[0x80]", c7[0..1]); // false (bare continuation)
    let c8 = [0xC0u8];
    validate_lit("[0xC0]", c8[0..1]); // false (2-byte lead, truncated)
    let c9 = [0xE0u8, 0x80u8];
    validate_lit("[0xE0,0x80]", c9[0..2]); // false (3-byte lead, only 1 continuation)
    let c10 = [0xFFu8];
    validate_lit("[0xFF]", c10[0..1]); // false (0b11111111, no valid lead)
    let c11 = [0xC5u8, 0x00u8];
    validate_lit("[0xC5,0x00]", c11[0..2]); // false (2-byte lead, 2nd not a continuation)

    // Property check — real strings' bytes are always valid UTF-8.
    report_str("Ascii123"); // true
    report_str("héllo"); // true (é is 2 bytes)
    report_str("café ☕"); // true (☕ is 3 bytes)
    report_str("日本語"); // true (3 bytes each)
}
