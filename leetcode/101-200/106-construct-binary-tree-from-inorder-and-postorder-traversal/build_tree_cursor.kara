// LeetCode #106: Construct Binary Tree from Inorder and Postorder Traversal — recursive
// with a single postorder cursor walking from the END.
//
// A distinct route to the same tree: instead of passing postorder *bounds* down each call
// (the ★), thread ONE cursor `cur` through the recursion as a `mut ref i64`, starting at the
// last postorder index and DECREASING. Reversed postorder is `root, right, left`, so each
// call consumes the next value (`postorder[cur]`) as its root, then recurses RIGHT first and
// LEFT second — the exact order the reversed walk lays the nodes out, so the single cursor
// visits them in sequence with no per-call postorder arithmetic. The inorder window alone
// bounds the recursion. The end-walking mirror of kata [#105](../105-construct-binary-tree-from-preorder-and-inorder-traversal/)'s
// front-walking cursor. Node type mirrors [#105] — a `shared struct TreeNode` (RC).

shared struct TreeNode {
    val: i64,
    mut left: Option[TreeNode],
    mut right: Option[TreeNode],
}

fn find_in(inorder: ref Vec[i64], in_lo: i64, in_hi: i64, target: i64) -> i64 {
    let mut i = in_lo;
    while i <= in_hi {
        if inorder[i] == target {
            return i;
        }
        i = i + 1i64;
    }
    -1i64
}

// Build the subtree spanning inorder[in_lo ..= in_hi]; `cur` is the shared read cursor into
// postorder, walked backward once per node in reversed-postorder order (root, then right,
// then left).
fn build(postorder: ref Vec[i64], inorder: ref Vec[i64], in_lo: i64, in_hi: i64, cur: mut ref i64) -> Option[TreeNode] {
    if in_lo > in_hi {
        return None;
    }
    let root_val = postorder[cur];
    cur = cur - 1i64;
    let mid = find_in(inorder, in_lo, in_hi, root_val);
    let node = TreeNode { val: root_val, left: None, right: None };
    node.right = build(postorder, inorder, mid + 1i64, in_hi, cur);
    node.left = build(postorder, inorder, in_lo, mid - 1i64, cur);
    Some(node)
}

fn build_tree(postorder: ref Vec[i64], inorder: ref Vec[i64]) -> Option[TreeNode] {
    let n = postorder.len();
    let mut cur = n - 1i64;
    build(postorder, inorder, 0i64, n - 1i64, mut cur)
}

fn ser(node: Option[TreeNode], acc: mut ref i64) {
    match node {
        None => { acc = (acc * 131i64 + 1i64) % 1000000007i64; }
        Some(n) => {
            acc = (acc * 131i64 + (n.val + 2i64)) % 1000000007i64;
            ser(n.left, acc);
            ser(n.right, acc);
        }
    }
}

fn main() {
    let base = [8i64, 4i64, 12i64, 2i64, 6i64, 10i64, 14i64, 1i64, 3i64, 5i64, 7i64, 9i64, 11i64, 13i64, 15i64];
    let mut acc = 0i64;
    let mut t = 0i64;
    while t < 8i64 {
        let mut nums: Vec[i64] = Vec.new();
        let mut k = 0i64;
        while k < base.len() {
            nums.push(base[(k + t) % base.len()]);
            k = k + 1i64;
        }
        let orig = insert_all(nums);
        let mut ino: Vec[i64] = Vec.new();
        let mut post: Vec[i64] = Vec.new();
        inorder_of(orig, mut ino);
        postorder_of(orig, mut post);

        let rebuilt = build_tree(post, ino);
        let mut s = 0i64;
        ser(rebuilt, mut s);
        acc = (acc * 1000003i64 + s) % 1000000007i64;
        println(f"tree {t}: sig {s}");
        t = t + 1i64;
    }
    println(f"sink: {acc}");
}

// --- helpers to generate consistent (inorder, postorder) inputs from a reference tree ---

fn bst_insert(root: Option[TreeNode], v: i64) -> Option[TreeNode] {
    match root {
        None => Some(TreeNode { val: v, left: None, right: None }),
        Some(n) => {
            if v < n.val {
                n.left = bst_insert(n.left, v);
            } else {
                n.right = bst_insert(n.right, v);
            }
            Some(n)
        }
    }
}

fn insert_all(nums: Vec[i64]) -> Option[TreeNode] {
    let mut root: Option[TreeNode] = None;
    let mut i = 0i64;
    while i < nums.len() {
        root = bst_insert(root, nums[i]);
        i = i + 1i64;
    }
    root
}

fn inorder_of(node: Option[TreeNode], out: mut ref Vec[i64]) {
    match node {
        None => {}
        Some(n) => {
            inorder_of(n.left, out);
            out.push(n.val);
            inorder_of(n.right, out);
        }
    }
}

fn postorder_of(node: Option[TreeNode], out: mut ref Vec[i64]) {
    match node {
        None => {}
        Some(n) => {
            postorder_of(n.left, out);
            postorder_of(n.right, out);
            out.push(n.val);
        }
    }
}
