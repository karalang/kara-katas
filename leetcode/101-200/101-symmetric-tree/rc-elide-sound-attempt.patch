@@ -0,0 +1,397 @@
+//! RC-elision safety analysis (env `KARAC_RC_ELIDE_REF_PARAMS`).
+//!
+//! The ownership pass classifies a parameter that is only read (never
+//! mutated / consumed / escaped) as [`OwnershipMode::Ref`] — a borrow. For a
+//! `shared` / `Option[shared]` such param, codegen normally still emits the
+//! caller-side retain (`rc_inc`) and the callee-side scope-exit release
+//! (`rc_dec`). That pair is *balanced*: when the caller keeps the referent
+//! alive across the call, deleting both is a no-op that removes real RC
+//! traffic (see the read-only tree walk in kata #101 — a ~30% wall-time win).
+//!
+//! But the deletion is only sound when the caller genuinely keeps the argument
+//! alive for the call's whole duration. That holds when the argument is a
+//! **place rooted at a named binding** (`x`, `n.left`, `v[i]`, `t.0`, `self`):
+//! the caller owns the root and drops it at *its* scope exit, so the borrowed
+//! ref stays live and the callee needs no ref of its own. It does **not** hold
+//! for a **fresh rvalue** (`Some(x)`, a call return, a struct literal, …): the
+//! `+1` there comes from the *producer* and the callee's exit `rc_dec` is what
+//! consumes it — elide that dec and the producer's ref leaks.
+//!
+//! So this pass computes, whole-program, exactly the `ref` params that are
+//! safe to elide: a `ref` param of function `F` at position `i` is elidable
+//! iff **every** call `F(…)` passes a place-rooted argument at `i`, and `F`'s
+//! name is never used as a value (an indirect call could pass anything). It is
+//! deliberately conservative — anything it cannot prove safe, it drops, so the
+//! worst case is a missed optimization, never a leak. Codegen consumes the
+//! result via `borrowed_arg_skip` / `borrowed_param_dec_skip`.
+//!
+//! The traversal is an **exhaustive** `match` over every `ExprKind` /
+//! `StmtKind` (no `_` arm): a call nested anywhere must be seen, and a future
+//! AST variant will fail to compile until it is handled here — the same
+//! fail-closed discipline the leak-safety depends on.
+
+use crate::ast::{
+    Block, Expr, ExprKind, ImplItem, Item, ParsedInterpolationPart, Program, Stmt, StmtKind,
+    TraitItem,
+};
+use crate::ownership::OwnershipMode;
+use std::collections::{HashMap, HashSet};
+
+/// A place expression whose root is a named binding — `x`, `x.f`, `x.f[i].g`,
+/// `self`, `self.state`. The caller owns the root binding and drops it at its
+/// own scope exit, so a borrow handed to a callee stays live for the call.
+/// A chain rooted at a call/`Some(...)`/literal is NOT a place here (its root
+/// is a fresh temp), so those callers are treated as unsafe — conservative.
+fn is_place_rooted(expr: &Expr) -> bool {
+    match &expr.kind {
+        ExprKind::Identifier(_) | ExprKind::SelfValue => true,
+        ExprKind::FieldAccess { object, .. }
+        | ExprKind::TupleIndex { object, .. }
+        | ExprKind::Index { object, .. } => is_place_rooted(object),
+        _ => false,
+    }
+}
+
+struct Scan<'a> {
+    /// Function names known to the ownership pass (candidates for elision).
+    fn_names: &'a HashSet<&'a str>,
+    /// Function names seen at least once as the direct callee of a
+    /// `Call { callee: Identifier(name), .. }` — i.e. a free-function call
+    /// whose arguments this pass has fully observed. Only these may elide;
+    /// a function reached solely through `MethodCall` (methods) or never
+    /// called at all is excluded, since its argument shapes are not tracked.
+    called: HashSet<String>,
+    /// (callee, position) that some direct call passes a non-place argument to.
+    unsafe_pos: HashMap<String, HashSet<usize>>,
+    /// Function names used as a *value* (not the direct callee of a call) —
+    /// their call sites are not all visible, so no param of theirs may elide.
+    escaped: HashSet<String>,
+}
+
+impl<'a> Scan<'a> {
+    fn walk_block(&mut self, block: &Block) {
+        for stmt in &block.stmts {
+            self.walk_stmt(stmt);
+        }
+        if let Some(tail) = &block.final_expr {
+            self.walk_expr(tail);
+        }
+    }
+
+    fn walk_stmt(&mut self, stmt: &Stmt) {
+        match &stmt.kind {
+            StmtKind::Let { value, .. }
+            | StmtKind::LetElse { value, .. }
+            | StmtKind::Expr(value) => self.walk_expr(value),
+            StmtKind::LetUninit { .. } => {}
+            StmtKind::Defer { body } | StmtKind::ErrDefer { body, .. } => self.walk_block(body),
+            StmtKind::Assign { target, value } | StmtKind::CompoundAssign { target, value, .. } => {
+                self.walk_expr(target);
+                self.walk_expr(value);
+            }
+            StmtKind::MultiAssign { targets, values } => {
+                for t in targets {
+                    self.walk_expr(t);
+                }
+                for v in values {
+                    self.walk_expr(v);
+                }
+            }
+        }
+        // A `LetElse`'s else block also holds exprs.
+        if let StmtKind::LetElse { else_block, .. } = &stmt.kind {
+            self.walk_block(else_block);
+        }
+    }
+
+    fn walk_expr(&mut self, expr: &Expr) {
+        match &expr.kind {
+            // A direct call `f(a, b, …)` to a known free function: record any
+            // non-place argument position, and DO NOT count the callee
+            // identifier itself as an escape (it is called, not passed).
+            ExprKind::Call { callee, args } => {
+                let direct = match &callee.kind {
+                    ExprKind::Identifier(name) if self.fn_names.contains(name.as_str()) => {
+                        self.called.insert(name.clone());
+                        for (i, arg) in args.iter().enumerate() {
+                            if !is_place_rooted(&arg.value) {
+                                self.unsafe_pos.entry(name.clone()).or_default().insert(i);
+                            }
+                        }
+                        true
+                    }
+                    _ => false,
+                };
+                if !direct {
+                    self.walk_expr(callee);
+                }
+                for arg in args {
+                    self.walk_expr(&arg.value);
+                }
+            }
+            // Any other appearance of a known function name is a value use
+            // (passed as an argument, stored, returned, …) — exclude every
+            // param of that function from elision, since its call sites are
+            // not all statically visible here.
+            ExprKind::Identifier(name) => {
+                if self.fn_names.contains(name.as_str()) {
+                    self.escaped.insert(name.clone());
+                }
+            }
+
+            ExprKind::MethodCall { object, args, .. } => {
+                self.walk_expr(object);
+                for arg in args {
+                    self.walk_expr(&arg.value);
+                }
+            }
+            ExprKind::OptionalChain { object, args, .. } => {
+                self.walk_expr(object);
+                if let Some(args) = args {
+                    for arg in args {
+                        self.walk_expr(&arg.value);
+                    }
+                }
+            }
+
+            // Leaves — no sub-expressions.
+            ExprKind::Integer(..)
+            | ExprKind::Float(..)
+            | ExprKind::CharLit(..)
+            | ExprKind::ByteLit(..)
+            | ExprKind::StringLit(..)
+            | ExprKind::MultiStringLit(..)
+            | ExprKind::CStringLit { .. }
+            | ExprKind::Bool(..)
+            | ExprKind::Path { .. }
+            | ExprKind::SelfValue
+            | ExprKind::SelfType
+            | ExprKind::PipePlaceholder
+            | ExprKind::OffsetOf { .. }
+            | ExprKind::Continue { .. }
+            | ExprKind::Error => {}
+
+            // `f"… {e} …"` — interpolation holds sub-expressions.
+            ExprKind::InterpolatedStringLit(parts) => {
+                for part in parts {
+                    if let ParsedInterpolationPart::Expr(e) = part {
+                        self.walk_expr(e);
+                    }
+                }
+            }
+
+            ExprKind::Binary { left, right, .. }
+            | ExprKind::NilCoalesce { left, right }
+            | ExprKind::Pipe { left, right } => {
+                self.walk_expr(left);
+                self.walk_expr(right);
+            }
+            ExprKind::Unary { operand, .. } => self.walk_expr(operand),
+            ExprKind::Question(inner) => self.walk_expr(inner),
+            ExprKind::FieldAccess { object, .. } | ExprKind::TupleIndex { object, .. } => {
+                self.walk_expr(object)
+            }
+            ExprKind::Index { object, index } => {
+                self.walk_expr(object);
+                self.walk_expr(index);
+            }
+            ExprKind::Cast { expr, .. } => self.walk_expr(expr),
+
+            ExprKind::Block(b)
+            | ExprKind::Comptime(b)
+            | ExprKind::Unsafe(b)
+            | ExprKind::Try(b)
+            | ExprKind::Seq(b)
+            | ExprKind::Par(b) => self.walk_block(b),
+            ExprKind::LabeledBlock { body, .. } | ExprKind::Loop { body, .. } => {
+                self.walk_block(body)
+            }
+
+            ExprKind::If {
+                condition,
+                then_block,
+                else_branch,
+            } => {
+                self.walk_expr(condition);
+                self.walk_block(then_block);
+                if let Some(e) = else_branch {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::IfLet {
+                value,
+                then_block,
+                else_branch,
+                ..
+            } => {
+                self.walk_expr(value);
+                self.walk_block(then_block);
+                if let Some(e) = else_branch {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::Match { scrutinee, arms } => {
+                self.walk_expr(scrutinee);
+                for arm in arms {
+                    if let Some(g) = &arm.guard {
+                        self.walk_expr(g);
+                    }
+                    self.walk_expr(&arm.body);
+                }
+            }
+            ExprKind::While {
+                condition, body, ..
+            } => {
+                self.walk_expr(condition);
+                self.walk_block(body);
+            }
+            ExprKind::WhileLet { value, body, .. } => {
+                self.walk_expr(value);
+                self.walk_block(body);
+            }
+            ExprKind::For { iterable, body, .. } => {
+                self.walk_expr(iterable);
+                self.walk_block(body);
+            }
+            ExprKind::Closure { body, .. } => self.walk_expr(body),
+            ExprKind::Return(inner) => {
+                if let Some(e) = inner {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::Break { value, .. } => {
+                if let Some(e) = value {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::Tuple(elems) | ExprKind::ArrayLiteral(elems) => {
+                for e in elems {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::PrefixCollectionLiteral { items, .. } => {
+                for e in items {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::RepeatLiteral { value, count, .. } => {
+                self.walk_expr(value);
+                self.walk_expr(count);
+            }
+            ExprKind::MapLiteral(pairs) => {
+                for (k, v) in pairs {
+                    self.walk_expr(k);
+                    self.walk_expr(v);
+                }
+            }
+            ExprKind::StructLiteral { fields, spread, .. } => {
+                for f in fields {
+                    self.walk_expr(&f.value);
+                }
+                if let Some(s) = spread {
+                    self.walk_expr(s);
+                }
+            }
+            ExprKind::Range { start, end, .. } => {
+                if let Some(e) = start {
+                    self.walk_expr(e);
+                }
+                if let Some(e) = end {
+                    self.walk_expr(e);
+                }
+            }
+            ExprKind::Lock { mutex, body, .. } => {
+                self.walk_expr(mutex);
+                self.walk_block(body);
+            }
+            ExprKind::Providers { bindings, body } => {
+                for b in bindings {
+                    self.walk_expr(&b.value);
+                }
+                self.walk_block(body);
+            }
+        }
+    }
+}
+
+/// Every function body in the program, so call sites in methods and free
+/// functions alike are seen.
+fn walk_all_bodies(program: &Program, scan: &mut Scan) {
+    fn walk_item(item: &Item, scan: &mut Scan) {
+        match item {
+            Item::Function(f) => scan.walk_block(&f.body),
+            Item::ImplBlock(b) => {
+                for inner in &b.items {
+                    if let ImplItem::Method(m) = inner {
+                        scan.walk_block(&m.body);
+                    }
+                }
+            }
+            Item::TraitDef(t) => {
+                for inner in &t.items {
+                    if let TraitItem::Method(m) = inner {
+                        if let Some(body) = &m.body {
+                            scan.walk_block(body);
+                        }
+                    }
+                }
+            }
+            _ => {}
+        }
+    }
+    for item in &program.items {
+        walk_item(item, scan);
+    }
+}
+
+/// Compute the `ref` parameters that are sound to RC-elide: keyed by function
+/// name, the `(param_name, position)` of every `Ref`-mode param that no call
+/// site passes a fresh rvalue and whose function never escapes as a value.
+pub fn safe_elidable_ref_params(
+    program: &Program,
+    param_modes: &HashMap<String, Vec<(String, OwnershipMode)>>,
+) -> HashMap<String, Vec<(String, usize)>> {
+    let fn_names: HashSet<&str> = param_modes.keys().map(|s| s.as_str()).collect();
+    // Public free functions have callers outside this compilation unit — their
+    // argument shapes are not all visible, so they can never elide.
+    let pub_fns: HashSet<&str> = program
+        .items
+        .iter()
+        .filter_map(|it| match it {
+            Item::Function(f) if f.is_pub => Some(f.name.as_str()),
+            _ => None,
+        })
+        .collect();
+    let mut scan = Scan {
+        fn_names: &fn_names,
+        called: HashSet::new(),
+        unsafe_pos: HashMap::new(),
+        escaped: HashSet::new(),
+    };
+    walk_all_bodies(program, &mut scan);
+
+    let mut out: HashMap<String, Vec<(String, usize)>> = HashMap::new();
+    for (fname, modes) in param_modes {
+        // Elide only functions we fully observed: directly called at least
+        // once, never used as a value, and not part of the public API.
+        if !scan.called.contains(fname)
+            || scan.escaped.contains(fname)
+            || pub_fns.contains(fname.as_str())
+        {
+            continue;
+        }
+        let bad = scan.unsafe_pos.get(fname);
+        let recs: Vec<(String, usize)> = modes
+            .iter()
+            .enumerate()
+            .filter(|(i, (_, m))| {
+                matches!(m, OwnershipMode::Ref) && !bad.is_some_and(|s| s.contains(i))
+            })
+            .map(|(i, (n, _))| (n.clone(), i))
+            .collect();
+        if !recs.is_empty() {
+            out.insert(fname.clone(), recs);
+        }
+    }
+    out
+}
