// LeetCode #103: Construct Binary Tree from Preorder and Inorder Traversal — recursive
// with a single advancing preorder cursor.
//
// A distinct route to the same tree: instead of passing preorder *bounds* down each call
// (the ★), thread ONE shared cursor `cur` through the recursion as a `mut ref i64`. Each
// call consumes the next preorder value as its root (`cur` advances by one), splits the
// inorder window at the root, then recurses LEFT first and RIGHT second — the exact order
// preorder lays the nodes out, so the single cursor visits them in the right sequence with
// no per-call preorder arithmetic. The inorder window (`in_lo..in_hi`) alone bounds the
// recursion. Node type mirrors kata [#102](../102-binary-tree-level-order-traversal/) —
// a `shared struct TreeNode` (RC); the cursor is a plain `mut ref i64`, no shared worklist.

shared struct TreeNode {
    val: i64,
    mut left: Option[TreeNode],
    mut right: Option[TreeNode],
}

fn find_in(inorder: ref Vec[i64], in_lo: i64, in_hi: i64, target: i64) -> i64 {
    let mut i = in_lo;
    while i <= in_hi {
        if inorder[i] == target {
            return i;
        }
        i = i + 1i64;
    }
    -1i64
}

// Build the subtree spanning inorder[in_lo ..= in_hi]; `cur` is the shared read cursor into
// preorder, advanced once per node in preorder order (root, then all of left, then right).
fn build(preorder: ref Vec[i64], inorder: ref Vec[i64], in_lo: i64, in_hi: i64, cur: mut ref i64) -> Option[TreeNode] {
    if in_lo > in_hi {
        return None;
    }
    // Consume this subtree's root from preorder, then advance the shared cursor. (Indexing
    // reads the cursor through the `mut ref` via the arithmetic `cur - 1i64` after the bump.)
    cur = cur + 1i64;
    let root_val = preorder[cur - 1i64];
    let mid = find_in(inorder, in_lo, in_hi, root_val);
    let node = TreeNode { val: root_val, left: None, right: None };
    node.left = build(preorder, inorder, in_lo, mid - 1i64, cur);
    node.right = build(preorder, inorder, mid + 1i64, in_hi, cur);
    Some(node)
}

fn build_tree(preorder: ref Vec[i64], inorder: ref Vec[i64]) -> Option[TreeNode] {
    let mut cur = 0i64;
    let n = inorder.len();
    build(preorder, inorder, 0i64, n - 1i64, mut cur)
}

fn ser(node: Option[TreeNode], acc: mut ref i64) {
    match node {
        None => { acc = (acc * 131i64 + 1i64) % 1000000007i64; }
        Some(n) => {
            acc = (acc * 131i64 + (n.val + 2i64)) % 1000000007i64;
            ser(n.left, acc);
            ser(n.right, acc);
        }
    }
}

fn main() {
    let base = [8i64, 4i64, 12i64, 2i64, 6i64, 10i64, 14i64, 1i64, 3i64, 5i64, 7i64, 9i64, 11i64, 13i64, 15i64];
    let mut acc = 0i64;
    let mut t = 0i64;
    while t < 8i64 {
        let mut nums: Vec[i64] = Vec.new();
        let mut k = 0i64;
        while k < base.len() {
            nums.push(base[(k + t) % base.len()]);
            k = k + 1i64;
        }
        let orig = insert_all(nums);
        let mut pre: Vec[i64] = Vec.new();
        let mut ino: Vec[i64] = Vec.new();
        preorder_of(orig, mut pre);
        inorder_of(orig, mut ino);

        let rebuilt = build_tree(pre, ino);
        let mut s = 0i64;
        ser(rebuilt, mut s);
        acc = (acc * 1000003i64 + s) % 1000000007i64;
        println(f"tree {t}: sig {s}");
        t = t + 1i64;
    }
    println(f"sink: {acc}");
}

// --- helpers to generate consistent (preorder, inorder) inputs from a reference tree ---

fn bst_insert(root: Option[TreeNode], v: i64) -> Option[TreeNode] {
    match root {
        None => Some(TreeNode { val: v, left: None, right: None }),
        Some(n) => {
            if v < n.val {
                n.left = bst_insert(n.left, v);
            } else {
                n.right = bst_insert(n.right, v);
            }
            Some(n)
        }
    }
}

fn insert_all(nums: Vec[i64]) -> Option[TreeNode] {
    let mut root: Option[TreeNode] = None;
    let mut i = 0i64;
    while i < nums.len() {
        root = bst_insert(root, nums[i]);
        i = i + 1i64;
    }
    root
}

fn preorder_of(node: Option[TreeNode], out: mut ref Vec[i64]) {
    match node {
        None => {}
        Some(n) => {
            out.push(n.val);
            preorder_of(n.left, out);
            preorder_of(n.right, out);
        }
    }
}

fn inorder_of(node: Option[TreeNode], out: mut ref Vec[i64]) {
    match node {
        None => {}
        Some(n) => {
            inorder_of(n.left, out);
            out.push(n.val);
            inorder_of(n.right, out);
        }
    }
}
